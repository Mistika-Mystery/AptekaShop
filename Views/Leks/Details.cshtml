@model apteka.Models.Lek
@{
    ViewData["Title"] = "Детали лекарства";
    var userRole = Context.Session.GetString("UserRole")?.Trim().ToLowerInvariant();
    var isAdmin = userRole == "admin";
}

<h1>Детали лекарства</h1>

<div>
    <h4>Lek</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Naz)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Naz)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Qena)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Qena)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Foto)
        </dt>
        <dd class = "col-sm-10">
            @if (!string.IsNullOrWhiteSpace(Model.Foto))
            {
                <img src="~/Img/@Model.Foto" alt="@Model.Naz" style="max-width: 250px;" />
            }
            else
            {
                <span>Изображение не выбрано</span>
            }
        </dd>
    </dl>
</div>
<div>
    @if (isAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model?.IDL">Изменить</a>
        <span>|</span>
    }
    <a asp-action="Index">Назад к каталогу</a>
</div>
