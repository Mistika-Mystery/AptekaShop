@model IEnumerable<apteka.Models.Lek>
@{
    ViewData["Title"] = "Каталог";
    var userRole = Context.Session.GetString("UserRole")?.Trim().ToLowerInvariant();
    var isAdmin = userRole == "admin";
}

<h1>Каталог лекарств</h1>

@if (isAdmin)
{
    <p>
        <a asp-action="Create">Добавить лекарство</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Naz)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Qena)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Foto)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Naz)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Qena)
            </td>
            <td>
                @if (!string.IsNullOrWhiteSpace(item.Foto))
                {
                    <div>
                        <img src="~/Img/@item.Foto" alt="@item.Naz" style="max-width: 200px; max-height: 200px;" />
                    </div>
                }
                else
                {
                    <span>Изображение не выбрано</span>
                }
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.IDL">Подробнее</a>
                @if (isAdmin)
                {
                    <span>|</span>
                    <a asp-action="Edit" asp-route-id="@item.IDL">Изменить</a>
                    <span>|</span>
                    <a asp-action="Delete" asp-route-id="@item.IDL">Удалить</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>
