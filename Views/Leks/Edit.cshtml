@model apteka.Models.Lek

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Lek</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IDL" />
            <input type="hidden" asp-for="Foto" />
            <div class="form-group mb-3">
                <label asp-for="Naz" class="control-label"></label>
                <input asp-for="Naz" class="form-control" />
                <span asp-validation-for="Naz" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Qena" class="control-label"></label>
                <input asp-for="Qena" class="form-control" />
                <span asp-validation-for="Qena" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Текущее изображение</label>
                <input class="form-control" value="@(string.IsNullOrWhiteSpace(Model.Foto) ? "Изображение не выбрано" : Model.Foto)" readonly />
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Foto))
            {
                <div class="form-group mb-3">
                    <img src="~/Img/@Model.Foto" alt="@Model.Naz" style="max-width: 200px;" />
                </div>
            }
            <div class="form-group mb-3">
                <label class="control-label d-block">Новое изображение</label>
                <button type="button" class="btn btn-outline-primary" id="selectImageButton">
                    Выбрать изображение
                </button>
                <input type="file" class="d-none" id="imageFile" name="imageFile" accept="image/*" />
                <div class="form-text" id="selectedImageInfo">
                    @(string.IsNullOrWhiteSpace(Model.Foto)
                        ? "Файл изображения ещё не выбран."
                        : $"Текущее изображение: {Model.Foto}")
                </div>
                <span asp-validation-for="Foto" class="text-danger d-block"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const selectImageButton = document.getElementById('selectImageButton');
            const imageFileInput = document.getElementById('imageFile');
            const selectedInfo = document.getElementById('selectedImageInfo');
            const currentImageName = '@(Model.Foto ?? string.Empty)';

            selectImageButton.addEventListener('click', function () {
                imageFileInput.click();
            });

            imageFileInput.addEventListener('change', function () {
                if (imageFileInput.files.length > 0) {
                    selectedInfo.textContent = `Выбран файл: ${imageFileInput.files[0].name}`;
                    return;
                }

                selectedInfo.textContent = currentImageName
                    ? `Текущее изображение: ${currentImageName}`
                    : 'Файл изображения ещё не выбран.';
            });
        });
    </script>
}
